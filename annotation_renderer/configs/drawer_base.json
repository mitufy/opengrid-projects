{
  "$schema": "../schemas/annotation-render-config.schema.json",
  "extends": "base_scene.json",
  "job_name": "opengrid_drawer_defaults_base",
  "constants": {
    "drawer_shell_rotation_x_deg": 90,
    "drawer_container_rotation_x_deg": 0,
    "drawer_fit_render": {
      "fit_margin": 0.11
    },
    "drawer_common_defines": {
      "generate_drawer_stopper_clips": false,
      "view_drawer_overlapped": false,
      "horizontal_grids": 5,
      "vertical_grids": 2,
      "depth_grids": 5,
      "shell_slot_position": "Back"
    },
    "drawer_common_model": {
      "scad_file": "openconnect_drawer.scad",
      "defines": {
        "$constant": "drawer_common_defines"
      }
    },
    "drawer_shell_defines": {
      "generate_drawer_shell": true,
      "generate_drawer_container": false
    },
    "drawer_container_defines": {
      "generate_drawer_shell": false,
      "generate_drawer_container": true
    },
    "drawer_shell_material": {
      "color": "#eee9df",
      "roughness": 0.58
    },
    "drawer_container_material": {
      "color": "#ffffff",
      "roughness": 0.5
    },
    "drawer_shell_transform": {
      "location_mm": [
        "odd(horizontal_grids) * OG_TILE_SIZE / 2",
        0,
        "-OG_TILE_SIZE + odd(vertical_grids) * OG_TILE_SIZE / 2"
      ],
      "rotation_deg": [
        "drawer_shell_rotation_x_deg",
        0,
        0
      ]
    },
    "drawer_container_transform": {
      "location_mm": [
        "odd(horizontal_grids) * OG_TILE_SIZE / 2",
        "-(shell_ocslot_part_thickness + container_depth_clearance)",
        "-(vertical_grids * OG_TILE_SIZE - shell_thickness - container_height_clearance / 2)"
      ],
      "rotation_deg": [
        "drawer_container_rotation_x_deg",
        0,
        0
      ]
    },
    "drawer_object_defaults": {
      "model": {
        "$constant": "drawer_common_model"
      },
      "inherit_target_transform": false
    },
    "drawer_shell_object": {
      "id": "drawer_shell",
      "target_object": "drawer",
      "model": {
        "defines": {
          "$constant": "drawer_shell_defines"
        }
      },
      "material": {
        "$constant": "drawer_shell_material"
      },
      "transform": {
        "$constant": "drawer_shell_transform"
      }
    },
    "drawer_container_object": {
      "id": "drawer_container",
      "target_object": "drawer_container",
      "material_source_object": "drawer",
      "model": {
        "defines": {
          "$constant": "drawer_container_defines"
        }
      },
      "material": {
        "$constant": "drawer_container_material"
      },
      "transform": {
        "$constant": "drawer_container_transform"
      }
    },
    "drawer_grid_annotations": {
      "object": "drawer_shell",
      "chains": [
        {
          "ids": [
            "horizontal_grids"
          ],
          "label_offset_px": 42
        },
        {
          "ids": [
            "vertical_grids"
          ],
          "line_offset_px": 30,
          "label_offset_px": 30,
          "label_font_size_px": {
            "$constant": "annotation_label_font_size_px"
          }
        },
        {
          "ids": [
            "depth_grids"
          ],
          "line_offset_px": -38,
          "label_offset_px": -42
        }
      ],
      "image_labels": [
        {
          "id": "shell_slot_position",
          "value": "Back",
          "position": "top",
          "offset_px": [
            0,
            32
          ],
          "show_value": true,
          "font_size_px": {
            "$constant": "annotation_aux_label_font_size_px"
          }
        }
      ]
    }
  }
}
