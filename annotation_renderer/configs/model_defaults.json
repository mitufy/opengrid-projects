{
  "$schema": "../schemas/annotation-render-config.schema.json",
  "job_name": "opengrid_annotation_models",
  "constants": {
    "annotation_label_font_size_px": 22,
    "annotation_title_font_size_px": 34,
    "annotation_aux_label_font_size_px": 24,
    "annotation_font": "sans",
    "drawer_shell_rotation_x_deg": 90,
    "drawer_container_rotation_x_deg": 0,
    "blender_scene_scale": 0.001,
    "blender_scene_scale_vector": [
      "blender_scene_scale",
      "blender_scene_scale",
      "blender_scene_scale"
    ],
    "placeholder_transform": {
      "location_mm": [
        0,
        0,
        0
      ],
      "rotation_deg": [
        90,
        0,
        -90
      ],
      "scale": {
        "$constant": "blender_scene_scale_vector"
      }
    },
    "small_dimension_chain": {
      "line_offset_px": 28,
      "label_offset_px": 24,
      "label_font_size_px": {
        "$constant": "annotation_label_font_size_px"
      },
      "tick_length_px": 12,
      "line_width_px": 2.2,
      "extension_width_px": 1.2
    },
    "bottom_image_label": {
      "position": "bottom",
      "offset_px": [
        0,
        -24
      ],
      "font_size_px": {
        "$constant": "annotation_title_font_size_px"
      }
    },
    "drawer_fit_render": {
      "fit_margin": 0.11
    },
    "sturdy_hook_model": {
      "scad_file": "openconnect_sturdy_hook.scad",
      "defines": {
        "hook_length": 45,
        "hook_shape_type": "Circular"
      }
    },
    "sturdy_hook_annotations": {
      "style": {
        "line_alpha": 255,
        "line_width_px": 2.3,
        "extension_width_px": 1.1,
        "tick_length_px": 15,
        "radial_line_width_px": 2.1,
        "label_font_size_px": {
          "$constant": "annotation_label_font_size_px"
        },
        "angle_fill_color": "#dc2626",
        "image_label_margin_px": 32,
        "image_label_title_area": true,
        "image_label_title_padding_x_px": 34,
        "image_label_title_padding_y_px": 12,
        "image_label_title_radius_px": 18,
        "image_label_title_fill_color": "#ffffff",
        "image_label_title_fill_alpha": 224,
        "image_label_title_outline_color": "#000000",
        "image_label_title_outline_alpha": 255,
        "image_label_title_outline_width_px": 4,
        "image_label_title_min_width_px": 620,
        "image_label_title_bottom_margin_px": 18,
        "type_styles": {
          "grids": {
            "line_colors": [
              "#000000"
            ],
            "font": {
              "$constant": "annotation_font"
            },
            "text_shade": 1.0
          },
          "mm": {
            "line_colors": [
              "#2563eb"
            ],
            "font": {
              "$constant": "annotation_font"
            },
            "text_shade": 1.0
          },
          "radius": {
            "line_colors": [
              "#dc2626"
            ],
            "font": {
              "$constant": "annotation_font"
            },
            "text_shade": 1.0
          },
          "angle": {
            "line_colors": [
              "#dc2626"
            ],
            "font": {
              "$constant": "annotation_font"
            },
            "text_shade": 1.0
          }
        },
        "colors": {
          "hook_width": "#2563eb",
          "hook_thickness": "#2563eb",
          "hook_length": "#2563eb",
          "hook_vertical_grids": "#000000",
          "truss_vertical_grids": "#000000",
          "circular_tip_radius": "#dc2626",
          "circular_tip_radius_extent": "#dc2626",
          "circular_tip_angle": "#dc2626",
          "truss_angle_radius": "#dc2626",
          "truss_angle_extent": "#dc2626",
          "truss_max_angle": "#dc2626"
        }
      },
      "aliases": {
        "hook_vertical_grids": "hook_vgrids",
        "truss_vertical_grids": "truss_vgrids",
        "hook_shape_type": "hook_shape",
        "circular_tip_radius": "tip_radius",
        "circular_tip_radius_extent": "tip_radius",
        "circular_tip_angle": "tip_angle"
      },
      "chains": [
        {
          "ids": [
            "hook_width"
          ],
          "display_offset_mm": [
            0,
            0,
            0
          ],
          "line_offset_px": 0,
          "label_offset_px": 34
        },
        {
          "ids": [
            "hook_thickness",
            "hook_length"
          ],
          "label_offset_px": 40
        },
        {
          "ids": [
            "hook_vertical_grids",
            "truss_vertical_grids"
          ],
          "optional": true,
          "display_offset_mm": [
            -3,
            0,
            0
          ],
          "label_offset_px": 42
        }
      ],
      "angle_radius_callouts": [
        {
          "id": "circular_tip_angle_radius",
          "arc_id": "circular_tip_radius_extent",
          "radius_id": "circular_tip_radius",
          "angle_id": "circular_tip_angle",
          "optional": true,
          "angle_label_offset_px": 42,
          "angle_label_tangent_offset_px": 28,
          "radius_label_offset_px": -30,
          "angle_fill_alpha": 28
        },
        {
          "id": "truss_angle_detail",
          "arc_id": "truss_angle_extent",
          "radius_id": "truss_angle_radius",
          "angle_id": "truss_max_angle",
          "optional": true,
          "show_radius_label": false,
          "angle_label_offset_px": 34,
          "angle_fill_alpha": 28
        }
      ],
      "image_labels": [
        {
          "$constant": "bottom_image_label",
          "id": "hook_shape_type",
          "offset_px": [
            0,
            -6
          ],
          "show_value": true,
          "value_color": "#2563eb",
          "font_size_px": {
            "$constant": "annotation_title_font_size_px"
          }
        }
      ]
    },
    "sturdy_shelf_model": {
      "scad_file": "openconnect_sturdy_shelf.scad",
      "defines": {
        "shelf_type": "Standard",
        "add_texture": false
      }
    },
    "sturdy_shelf_annotations": {
      "chains": [
        {
          "ids": [
            "shelf_depth"
          ]
        },
        {
          "ids": [
            "shelf_width"
          ]
        },
        {
          "$constant": "small_dimension_chain",
          "ids": [
            "shelf_back_thickness"
          ]
        },
        {
          "$constant": "small_dimension_chain",
          "ids": [
            "shelf_bottom_thickness"
          ]
        }
      ],
      "image_labels": [
        {
          "$constant": "bottom_image_label",
          "id": "shelf_type",
          "show_value": true
        }
      ]
    },
    "drawer_common_defines": {
      "generate_drawer_stopper_clips": false,
      "view_drawer_overlapped": false,
      "horizontal_grids": 5,
      "vertical_grids": 2,
      "depth_grids": 5,
      "shell_slot_position": "Back"
    },
    "drawer_common_model": {
      "scad_file": "openconnect_drawer.scad",
      "defines": {
        "$constant": "drawer_common_defines"
      }
    },
    "drawer_shell_defines": {
      "generate_drawer_shell": true,
      "generate_drawer_container": false
    },
    "drawer_container_defines": {
      "generate_drawer_shell": false,
      "generate_drawer_container": true
    },
    "drawer_shell_material": {
      "color": "#eee9df",
      "roughness": 0.58
    },
    "drawer_container_material": {
      "color": "#ffffff",
      "roughness": 0.5
    },
    "drawer_shell_transform": {
      "location_mm": [
        "odd(horizontal_grids) * OG_TILE_SIZE / 2",
        0,
        "-OG_TILE_SIZE + odd(vertical_grids) * OG_TILE_SIZE / 2"
      ],
      "rotation_deg": [
        "drawer_shell_rotation_x_deg",
        0,
        0
      ]
    },
    "drawer_container_transform": {
      "location_mm": [
        "odd(horizontal_grids) * OG_TILE_SIZE / 2",
        "-(shell_ocslot_part_thickness + container_depth_clearance)",
        "-(vertical_grids * OG_TILE_SIZE - shell_thickness - container_height_clearance / 2)"
      ],
      "rotation_deg": [
        "drawer_container_rotation_x_deg",
        0,
        0
      ]
    },
    "drawer_object_defaults": {
      "model": {
        "$constant": "drawer_common_model"
      },
      "inherit_target_transform": false
    },
    "drawer_shell_object": {
      "id": "drawer_shell",
      "target_object": "drawer",
      "model": {
        "defines": {
          "$constant": "drawer_shell_defines"
        }
      },
      "material": {
        "$constant": "drawer_shell_material"
      },
      "transform": {
        "$constant": "drawer_shell_transform"
      }
    },
    "drawer_container_object": {
      "id": "drawer_container",
      "target_object": "drawer_container",
      "material_source_object": "drawer",
      "model": {
        "defines": {
          "$constant": "drawer_container_defines"
        }
      },
      "material": {
        "$constant": "drawer_container_material"
      },
      "transform": {
        "$constant": "drawer_container_transform"
      }
    },
    "drawer_grid_annotations": {
      "object": "drawer_shell",
      "chains": [
        {
          "ids": [
            "horizontal_grids"
          ],
          "label_offset_px": 42
        },
        {
          "ids": [
            "vertical_grids"
          ],
          "line_offset_px": 30,
          "label_offset_px": 30,
          "label_font_size_px": {
            "$constant": "annotation_label_font_size_px"
          }
        },
        {
          "ids": [
            "depth_grids"
          ],
          "line_offset_px": -38,
          "label_offset_px": -42
        }
      ],
      "image_labels": [
        {
          "id": "shell_slot_position",
          "value": "Back",
          "position": "top",
          "offset_px": [
            0,
            32
          ],
          "show_value": true,
          "font_size_px": {
            "$constant": "annotation_aux_label_font_size_px"
          }
        }
      ]
    }
  },
  "model": null,
  "scene": {
    "blend_file": "../assets/scenes/opengrid_wall_scene.blend",
    "target_object": "placeholder",
    "camera": "Camera",
    "replace_target_object": true,
    "inherit_target_transform": false,
    "transform": {
      "$constant": "placeholder_transform"
    }
  },
  "render": {
    "preset": "cycles_standard_scene"
  },
  "annotations": {},
  "variants": [
    {
      "name": "sturdy_hook_default",
      "job_name": "sturdy_hook_scene_45",
      "model": {
        "$constant": "sturdy_hook_model"
      },
      "annotations": {
        "$constant": "sturdy_hook_annotations"
      },
      "render": {
        "fit_margin": 0.14
      }
    },
    {
      "name": "sturdy_shelf_default",
      "job_name": "sturdy_shelf_scene_default",
      "model": {
        "$constant": "sturdy_shelf_model"
      },
      "annotations": {
        "$constant": "sturdy_shelf_annotations"
      }
    },
    {
      "name": "drawer_shell_default",
      "job_name": "openconnect_drawer_shell_scene_default",
      "model": null,
      "scene": {
        "object_defaults": {
          "$constant": "drawer_object_defaults"
        },
        "objects": [
          {
            "$constant": "drawer_shell_object"
          }
        ]
      },
      "render": {
        "$constant": "drawer_fit_render"
      },
      "annotations": {
        "$constant": "drawer_grid_annotations"
      }
    },
    {
      "name": "drawer_shell_container_default",
      "job_name": "openconnect_drawer_shell_container_scene_default",
      "model": null,
      "scene": {
        "object_defaults": {
          "$constant": "drawer_object_defaults"
        },
        "objects": [
          {
            "$constant": "drawer_shell_object"
          },
          {
            "$constant": "drawer_container_object"
          }
        ]
      },
      "render": {
        "$constant": "drawer_fit_render"
      },
      "annotations": {
        "$constant": "drawer_grid_annotations"
      }
    }
  ]
}
